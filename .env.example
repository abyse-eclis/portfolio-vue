# Supabase — frontend talks directly to the DB via the anon key.
# Get these from: Supabase Dashboard → Project → Settings → API
# IMPORTANT: enable Row Level Security (RLS) on every table before going live.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Set to "true" once the `submit-contact` Edge Function is deployed to route
# contact submissions through it (adds email notification + rate limiting).
VITE_USE_CONTACT_FN=false

# Canonical site URL — used by `npm run sitemap`. Defaults to the example domain.
VITE_SITE_URL=https://devfolio.example.com
